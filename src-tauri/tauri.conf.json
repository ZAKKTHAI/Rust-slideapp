{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "slideapp",
  "version": "0.1.0",
  "identifier": "dev.local.slideapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Slides",
        "width": 1280,
        "height": 800,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
